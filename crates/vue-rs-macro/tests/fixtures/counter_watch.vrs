<template>
  <button @click="increment()">{{ count.get() }}/{{ doubled.get() }}</button>
</template>

<script lang="rust">
use vue_rs_reactive::ref;
use vue_rs_reactive::watch;

let count = ref(0);
let doubled = ref(0);
let increment = move || count.set(count.get() + 1);
watch(move || count.get(), move |new, _old| doubled.set(*new * 2));
</script>
